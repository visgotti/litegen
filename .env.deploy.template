# LiteGen deploy config. Copy to `.env.deploy` (gitignored) and fill in.
#   cp .env.deploy.template .env.deploy
# deploy.js reads this file; values already in the real environment win.

# ── DigitalOcean (proxy + db droplet) ──
DO_API_KEY=<your-digitalocean-api-token>
DO_SSH_KEY_PATH=~/.ssh/id_ed25519
# Droplet shape — defaults are fine. ~$12/mo at s-1vcpu-2gb.
DO_REGION=nyc3
DO_SIZE=s-1vcpu-2gb
DO_IMAGE=ubuntu-24-04-x64
# Filled in automatically by `node deploy.js provision`. Leave blank.
DO_DROPLET_IP=

# ── GHCR (GitHub Container Registry — proxy image) ──
GHCR_USER=visgotti
GHCR_TOKEN=<github-pat-with-write:packages>

# Proxy build location:
#   ghcr      → build the image locally, push to GHCR, droplet pulls it.
#               Requires clean TLS egress to Docker Hub + crates.io.
#   ondroplet → build natively on the droplet (clean network, native amd64).
#               Use this behind a TLS-intercepting corporate proxy, or to
#               skip slow QEMU cross-builds. (GHCR_TOKEN not needed.)
PROXY_BUILD=ghcr

# ── Cloudflare (landing site → Pages) ──
CLOUDFLARE_API_TOKEN=<cloudflare-api-token>
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CF_PAGES_PROJECT=litegen-landing

# ── LiteGen proxy secrets (auto-generated + persisted on first run) ──
# Leave blank; deploy.js generates and writes them back here.
LITEGEN__MASTER_KEY=
POSTGRES_PASSWORD=

# ── Optional: provider keys baked into the hosted proxy ──
# OPENAI_API_KEY=
# REPLICATE_API_TOKEN=
# GOOGLE_API_KEY=
# FAL_KEY=
