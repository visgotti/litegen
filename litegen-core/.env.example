# Credentials for live provider integration tests (cargo test --test live_providers -- --ignored).
# Copy to litegen-core/.env and fill in the keys you have. Tests self-skip when
# their vars are absent, so you only need keys for the providers you want to run.

# ─── Simple API-key providers ────────────────────────────────────────────────
GOOGLE_API_KEY=           # Google Imagen/Gemini image + Veo video (AI Studio key)
LUMA_API_KEY=             # Luma Photon image + Dream Machine/Ray video
RUNWAY_API_KEY=           # Runway Gen-4 image + video (the API secret)
BFL_API_KEY=              # Black Forest Labs (FLUX)
IDEOGRAM_API_KEY=         # Ideogram
RECRAFT_API_TOKEN=        # Recraft
MINIMAX_API_KEY=          # MiniMax / Hailuo (image + video)
BYTEDANCE_API_KEY=        # ByteDance Seedream/Seedance (Volcengine Ark / BytePlus ModelArk key)
VIDU_API_KEY=             # Vidu
PIXVERSE_API_KEY=         # PixVerse
LEONARDO_API_KEY=         # Leonardo.Ai (image + video)

# ─── Signing-scheme providers ────────────────────────────────────────────────
# Kling — per-request JWT from an access key + secret key.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Amazon Bedrock Nova — AWS SigV4. Region defaults to us-east-1.
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1
# Nova Reel writes output to YOUR S3 bucket (required for the video test):
BEDROCK_S3_OUTPUT_URI=    # e.g. s3://my-bucket/litegen/

# Tencent Hunyuan — TC3-HMAC-SHA256. Region is ap-guangzhou only.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
