# ---- Server ----
NODE_ENV=development
PORT=4100
# Comma-separated CORS allowlist; "*" allows all (dev only).
CORS_ORIGINS=*

# ---- Database (Postgres) ----
DATABASE_URL=postgres://price:price@localhost:5433/price_api
# Auto-create schema from entities. Keep true in dev; ALWAYS false in production (use migrations).
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ---- Auth (OAuth2 client-credentials, self-issued JWT) ----
# HS256 secret used to sign access tokens. MUST be a long random string in production.
JWT_SECRET=change-me-in-production-please-32chars-min
# Access-token lifetime in seconds.
JWT_TTL_SECONDS=3600
JWT_ISSUER=litegen-price-api
JWT_AUDIENCE=litegen-price-api

# Bootstrap admin client created on first boot if it does not exist.
# Leave BOOTSTRAP_CLIENT_SECRET empty to skip bootstrap (recommended once you have clients).
BOOTSTRAP_CLIENT_ID=bootstrap-admin
BOOTSTRAP_CLIENT_SECRET=
BOOTSTRAP_CLIENT_SCOPES=pricing:read,pricing:admin

# ---- Rate limiting ----
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
# Stricter limit for the token endpoint.
THROTTLE_AUTH_LIMIT=10

# ---- Scraping ----
# Master switch for cron-scheduled scrapers.
SCRAPING_ENABLED=true
# HTTP timeout (ms) for a single provider fetch.
SCRAPE_TIMEOUT_MS=15000
# Consecutive failed runs before a price flips fresh/stale -> failed.
SCRAPE_STALE_AFTER_FAILURES=3

# Path to the canonical litegen model definitions, used ONLY by the dev/CI
# coverage check (no runtime coupling to litegen-core).
LITEGEN_MODELS_DIR=../../models
